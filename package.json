    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.8.3",
    "react-native-zalo-kit": "^5.0.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.3.2",
