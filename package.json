{
  "name": "asinu-lite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start --dev-client --clear",
    "start:dev": "./scripts/start-dev.sh",
    "android": "node ./node_modules/expo/bin/cli run:android",
    "ios": "node ./node_modules/expo/bin/cli run:ios",
    "web": "node ./node_modules/expo/bin/cli start --web",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "build:android": "cd android && ./gradlew bundleRelease",
    "build:android:release": "npm run build:android",
    "lint:assets": "node scripts/check-assets.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ant-design/react-native": "^5.4.3",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/native": "^7.0.14",
    "@tanstack/react-query": "^5.62.8",
    "clsx": "^2.1.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
