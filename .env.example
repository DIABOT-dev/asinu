# Frontend Environment Variables Template
# Copy this file to .env and fill in the values

# API Configuration
# For development: http://localhost:3000
# For production: https://your-api-domain.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Feature Flags
EXPO_PUBLIC_SHOW_MASCOT=true

# UI Options
EXPO_PUBLIC_DISABLE_CHARTS=0

# OAuth Configuration
# Set to 'true' to use mock OAuth for development without real OAuth setup
EXPO_PUBLIC_USE_MOCK_OAUTH=true

# Google OAuth Client IDs (get from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=726570048913-oq7rk69ronarv55lucd7it29t8ti0c32.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=726570048913-0oj1afglacg0h4p77toi6kvr6buh46j8.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=726570048913-atltseun4619ge72ba6itpiqc6hbjnr0.apps.googleusercontent.com

# Apple Sign In (get from Apple Developer)
# https://developer.apple.com/account/resources/identifiers/list/serviceId
EXPO_PUBLIC_APPLE_CLIENT_ID=com.asinu.lite.service

# Zalo OAuth (get from Zalo Developer)
# https://developers.zalo.me/
EXPO_PUBLIC_ZALO_APP_ID=1593272240133048788

# === Mobile Payment ===
# 'iap'    — Apple IAP + Google Play Billing (chuẩn store, đang scaffold)
# 'sepay'  — Cũ: QR + wallet (CHỈ dev / web build, KHÔNG submit App Store)
# 'hidden' — Ẩn flow nâng cấp Premium (cho submit App Review đầu)
EXPO_PUBLIC_PAYMENT_METHOD=hidden

# IAP product IDs — phải khớp product tạo trên App Store Connect + Play Console
EXPO_PUBLIC_IAP_PRODUCT_MONTHLY=asinu.premium.monthly
EXPO_PUBLIC_IAP_PRODUCT_YEARLY=asinu.premium.yearly
