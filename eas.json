{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "dev",
        "NODE_ENV": "development"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "dev",
        "NODE_ENV": "development"
      }
    },
    "simulator-standalone": {
      "developmentClient": false,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "dev",
        "NODE_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://asinu.top",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "416338225523-vs42boe39psg5k927thrhuq8doobb29h.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "416338225523-4ooh8cr3hd7r2skotlkohj40ppsm6s21.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "416338225523-e095rh2637h6fto5ia0gvnn8faeq96fd.apps.googleusercontent.com",
        "EXPO_PUBLIC_APPLE_CLIENT_ID": "com.asinu.lite.service",
        "EXPO_PUBLIC_ZALO_APP_ID": "1593272240133048788"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.1",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "prod",
        "EXPO_PUBLIC_API_BASE_URL": "https://asinu.top",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "416338225523-vs42boe39psg5k927thrhuq8doobb29h.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "416338225523-4ooh8cr3hd7r2skotlkohj40ppsm6s21.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "416338225523-e095rh2637h6fto5ia0gvnn8faeq96fd.apps.googleusercontent.com",
        "EXPO_PUBLIC_APPLE_CLIENT_ID": "com.asinu.lite.service",
        "EXPO_PUBLIC_ZALO_APP_ID": "1593272240133048788"
      }
    }
  }
}
